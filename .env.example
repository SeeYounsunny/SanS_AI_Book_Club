TELEGRAM_BOT_TOKEN=replace_me
# Book club members group chat id (e.g. -1001234567890)
MEMBER_CHAT_ID=replace_me
# Admin/ops group chat id (e.g. -1001234567890)
ADMIN_CHAT_ID=replace_me

TIMEZONE=Asia/Seoul
DB_PATH=./data/reading_club.sqlite3
# Railway / managed DB (recommended): set this to use Postgres
DATABASE_URL=

# Webhook mode (recommended)
# Public HTTPS URL Telegram can reach, e.g. https://example.com
WEBHOOK_URL=
# Local port to listen on (inside container / on server)
PORT=8080
# Optional: secret token header verification (recommended)
WEBHOOK_SECRET_TOKEN=

# Optional (Phase 1: discussion questions can be stubbed)
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings (taste snapshot without generative LLM)
EMBEDDINGS_PROVIDER=none
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
TASTE_BOOKMARKS_LIMIT=30
TASTE_MAX_CLUSTERS=4

# (Optional) LLM summary for taste (1-3 lines)
OPENAI_SUMMARY_MODEL=gpt-4o-mini
TASTE_SUMMARY_MAX_QUOTES=6
